{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uiux-dh.example/schemas/demo.schema.json",
  "title": "UIUX-DH Demo Entry",
  "description": "실제 사용 데모 1종의 메타 정보. system.json의 demos[] 엔트리 구조.",
  "type": "object",
  "required": ["id", "title", "uses"],
  "additionalProperties": false,
  "properties": {
    "id":          { "type": "string", "pattern": "^demo-[a-z][a-z0-9-]*$" },
    "title":       { "type": "string" },
    "description": { "type": "string" },
    "category":    { "enum": ["onboarding", "feed", "commerce", "utility", "profile", "communication", "navigation", "feedback"] },
    "uses": {
      "type": "array",
      "description": "data-uses 속성에서 파싱된 컴포넌트 id 및 토큰 이름 목록",
      "items": {
        "type": "string",
        "anyOf": [
          { "pattern": "^[a-z][a-z0-9-]*$", "description": "컴포넌트 id" },
          { "pattern": "^--[a-z][a-z0-9-]+$", "description": "CSS 변수명" }
        ]
      }
    },
    "sourceHtml": { "type": "string", "description": "index.html 내 앵커. 예: 'index.html#demo-foodorder'" }
  }
}
