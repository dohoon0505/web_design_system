{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://web-design-system.local/schemas/analysis.schema.json",
  "title": "Website Analysis",
  "description": "Structured analysis of a single web page. One file lives at analyses/{id}/analysis.json.",
  "type": "object",
  "required": ["id", "url", "title", "analyzedAt"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Slug used as folder name and hash route. Lowercase, digits, hyphens only."
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "The analyzed URL."
    },
    "title": {
      "type": "string",
      "description": "Human-readable site name shown in sidebar and headings."
    },
    "analyzedAt": {
      "type": "string",
      "format": "date",
      "description": "ISO date (YYYY-MM-DD) when the analysis was produced."
    },
    "summary": {
      "type": "string",
      "description": "One-paragraph overall impression."
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["src"],
        "properties": {
          "src": { "type": "string" },
          "caption": { "type": "string" }
        }
      }
    },
    "techStack": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frameworks": { "type": "array", "items": { "type": "string" } },
        "cssFrameworks": { "type": "array", "items": { "type": "string" } },
        "libraries": { "type": "array", "items": { "type": "string" } },
        "fonts": { "type": "array", "items": { "type": "string" } },
        "hosting": { "type": "string" },
        "cdn": { "type": "string" },
        "analytics": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    },
    "colors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary": { "type": "string" },
        "secondary": { "type": "string" },
        "background": { "type": "string" },
        "surface": { "type": "string" },
        "text": { "type": "string" },
        "textMuted": { "type": "string" },
        "border": { "type": "string" },
        "accent": { "type": "string" },
        "extracted": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["hex"],
            "properties": {
              "hex": { "type": "string", "pattern": "^#[0-9A-Fa-f]{3,8}$" },
              "role": { "type": "string" },
              "usage": { "type": "string" }
            }
          }
        }
      }
    },
    "typography": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "headingFont": { "type": "string" },
        "bodyFont": { "type": "string" },
        "monoFont": { "type": ["string", "null"] },
        "fontSources": { "type": "array", "items": { "type": "string" } },
        "sizes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "value": { "type": "string" },
              "usage": { "type": "string" }
            }
          }
        },
        "weights": { "type": "array", "items": { "type": ["string", "number"] } },
        "notes": { "type": "string" }
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxWidth": { "type": "string" },
        "grid": { "type": "string" },
        "spacing": { "type": "string" },
        "breakpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "minWidth": { "type": "string" }
            }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "variants": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    },
    "iconography": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "library": { "type": "string" },
        "style": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "interactions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "animations": { "type": "string" },
        "transitions": { "type": "string" },
        "hover": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contrastRatio": { "type": "string" },
        "keyboard": { "type": "string" },
        "aria": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "notes": {
      "type": "string",
      "description": "Free-form additional observations."
    }
  }
}
