{
  "$schema": "../schemas/component.schema.json",
  "id": "button",
  "name": "Button",
  "version": "0.3.2",
  "category": "interactive",
  "description": "액션을 실행하는 상호작용 요소. 7변형 × 5크기 × 6상태.",
  "variants": [
    {
      "id": "primary",
      "label": "Primary",
      "description": "주요 액션. 한 화면에 1개 권장.",
      "html": "<button class=\"btn btn-primary btn-md\">저장</button>",
      "tokens": { "bg": "--sm-interactive-brand-default", "fg": "--sm-content-onBrand", "hover": "--sm-interactive-brand-hover" }
    },
    {
      "id": "tonal",
      "label": "Tonal",
      "description": "보조 강조. 브랜드 subtle 배경.",
      "html": "<button class=\"btn btn-tonal btn-md\">더 알아보기</button>",
      "tokens": { "bg": "--sm-interactive-brand-subtle", "fg": "--sm-content-brand" }
    },
    {
      "id": "secondary",
      "label": "Secondary",
      "description": "중립 액션. 뉴트럴 배경.",
      "html": "<button class=\"btn btn-secondary btn-md\">취소</button>"
    },
    {
      "id": "outline",
      "label": "Outline",
      "description": "테두리 기반, 투명 배경.",
      "html": "<button class=\"btn btn-outline btn-md\">옵션</button>"
    },
    {
      "id": "ghost",
      "label": "Ghost",
      "description": "배경·테두리 없음. 텍스트만.",
      "html": "<button class=\"btn btn-ghost btn-md\">나중에</button>"
    },
    {
      "id": "dark",
      "label": "Dark",
      "description": "콘트라스트 강조. 어두운 배경.",
      "html": "<button class=\"btn btn-dark btn-md\">확인</button>"
    },
    {
      "id": "danger",
      "label": "Danger",
      "description": "되돌릴 수 없는 액션 (삭제 등).",
      "html": "<button class=\"btn btn-danger btn-md\">삭제</button>",
      "tokens": { "bg": "--sm-status-error", "fg": "#fff" }
    }
  ],
  "sizes": [
    { "id": "btn-sm",   "height": 32, "fontSize": 12, "padX": 12 },
    { "id": "btn-md",   "height": 40, "fontSize": 14, "padX": 16 },
    { "id": "btn-base", "height": 44, "fontSize": 14, "padX": 18 },
    { "id": "btn-lg",   "height": 48, "fontSize": 15, "padX": 20 },
    { "id": "btn-xl",   "height": 56, "fontSize": 16, "padX": 24 }
  ],
  "states": ["rest", "hover", "active", "focus", "disabled", "loading"],
  "modifiers": [
    { "class": "btn-pill",  "description": "fully rounded" },
    { "class": "btn-icon",  "description": "아이콘만" },
    { "class": "btn-fab",   "description": "플로팅 액션" },
    { "class": "btn-full",  "description": "width: 100%" }
  ],
  "tokens": {
    "bg":      "--cm-button-{variant}-bg",
    "fg":      "--cm-button-{variant}-fg",
    "border":  "--cm-button-{variant}-border",
    "radius":  "--cm-button-radius",
    "hover":   "--cm-button-{variant}-hover"
  },
  "accessibility": {
    "role": "button",
    "keyboardSupport": ["Enter", "Space"],
    "minTouchTarget": 44,
    "focusRing": "--sm-border-focus",
    "ariaNotes": [
      "로딩 상태: aria-busy=true",
      "비활성: disabled 속성 (aria-disabled보다 우선)",
      "아이콘 전용 버튼: aria-label 필수"
    ]
  },
  "whenToUse": ["즉시 액션 실행", "폼 제출", "결정 확인"],
  "whenNotToUse": ["페이지 이동만 하면 링크(a) 사용", "토글 상태면 Toggle/Switch"],
  "uxWriting": [
    "동사로 끝나기 (저장, 삭제, 계속)",
    "4-6자 이내 권장",
    "danger variant: 구체적 결과 명시 (삭제 → 프로젝트 삭제)"
  ],
  "usedInDemos": ["demo-login", "demo-signup", "demo-pricing", "demo-todo", "demo-checkout", "demo-social", "demo-foodorder"],
  "relatedDocs": { "md": "components/button.md", "sourceHtml": "index.html#button" }
}
