{
  "$schema": "../schemas/component.schema.json",
  "id": "appbar",
  "name": "Top App Bar",
  "version": "0.3.2",
  "category": "navigation",
  "description": "모바일 상단 고정 헤더. 제목·뒤로가기·주요 액션을 담음. 5가지 표준 변형.",
  "variants": [
    {
      "id": "center-back-more",
      "label": "Center title · back + more",
      "description": "제목 중앙. 좌측 뒤로가기, 우측 more",
      "html": "<div class=\"m-topbar\"><div class=\"m-back\"><svg class=\"ico\"><use href=\"#i-arrow-left\"/></svg></div><h2 class=\"title-center\">제목</h2><div class=\"action\"><svg class=\"ico\"><use href=\"#i-more-v\"/></svg></div></div>"
    },
    {
      "id": "left-back-more",
      "label": "Left title · back + more",
      "html": "<div class=\"m-topbar\"><div class=\"m-back\"><svg class=\"ico\"><use href=\"#i-arrow-left\"/></svg></div><h2>제목</h2><div class=\"action\"><svg class=\"ico\"><use href=\"#i-more-v\"/></svg></div></div>"
    },
    {
      "id": "left-back-next",
      "label": "Left title · back + 다음(text)",
      "description": "폼 상단. 텍스트 액션 (다음/저장/완료)",
      "html": "<div class=\"m-topbar\"><div class=\"m-back\">...</div><h2>회원가입</h2><div class=\"m-action\">다음</div></div>"
    },
    {
      "id": "left-close",
      "label": "Left title · close",
      "description": "모달형 화면. close 아이콘",
      "html": "<div class=\"m-topbar\"><div class=\"m-back\"><svg class=\"ico\"><use href=\"#i-close\"/></svg></div><h2>제목</h2></div>"
    },
    {
      "id": "left-next",
      "label": "Left title · 다음(text)",
      "description": "뒤로가기 없음. 최초 진입 폼",
      "html": "<div class=\"m-topbar\"><h2>시작하기</h2><div class=\"m-action\">건너뛰기</div></div>"
    },
    {
      "id": "large-title",
      "label": "Large Title",
      "description": "iOS 스타일 스크롤 확장 헤더",
      "html": "<div class=\"m-topbar-large\"><h1>홈</h1></div>"
    }
  ],
  "states": ["rest", "scrolled (shadow appear)"],
  "tokens": {
    "bg":         "--sm-background-default",
    "border":     "--sm-border-subtle",
    "title":      "--sm-content-primary",
    "action":     "--sm-content-brand",
    "height":     "52px",
    "iconSize":   "22px"
  },
  "accessibility": {
    "role": "banner (페이지 헤더)",
    "ariaNotes": [
      "제목은 <h1> 또는 <h2>",
      "back 버튼: aria-label=\"뒤로가기\"",
      "close 버튼: aria-label=\"닫기\""
    ]
  },
  "whenToUse": ["모바일 화면 상단 고정", "제목 · 주 액션 표시"],
  "whenNotToUse": ["탭 기반 홈 → Tab Bar만 사용", "오버레이 내부에서 자체 close 있으면 생략 가능"],
  "uxWriting": [
    "제목은 명사 (설정, 알림)",
    "텍스트 액션은 2-3자 (다음, 저장, 완료)",
    "현재 화면 이름만 표시 (앱 이름 중복 금지)"
  ],
  "usedInDemos": ["demo-login", "demo-signup", "demo-store", "demo-pricing", "demo-calendar", "demo-todo", "demo-chat", "demo-checkout", "demo-notify", "demo-mypage"],
  "relatedDocs": { "md": "components/top-app-bar.md", "sourceHtml": "index.html#appbar" }
}
