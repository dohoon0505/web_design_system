{
  "$schema": "../schemas/component.schema.json",
  "id": "badge",
  "name": "Badge",
  "version": "0.2.0",
  "category": "feedback",
  "description": "상태·카테고리·숫자 알림을 짧게 표시하는 작은 라벨.",
  "variants": [
    { "id": "brand",   "label": "Brand",   "html": "<span class=\"badge badge-brand\">NEW</span>",    "tokens": { "bg": "--sm-interactive-brand-subtle", "fg": "--sm-content-brand" } },
    { "id": "success", "label": "Success", "html": "<span class=\"badge badge-success\">완료</span>",   "tokens": { "bg": "--sm-status-success-subtle", "fg": "--sm-status-success" } },
    { "id": "warning", "label": "Warning", "html": "<span class=\"badge badge-warning\">대기</span>",   "tokens": { "bg": "--sm-status-warning-subtle", "fg": "--sm-status-warning" } },
    { "id": "error",   "label": "Error",   "html": "<span class=\"badge badge-error\">오류</span>",    "tokens": { "bg": "--sm-status-error-subtle", "fg": "--sm-status-error" } },
    { "id": "info",    "label": "Info",    "html": "<span class=\"badge badge-info\">안내</span>",     "tokens": { "bg": "--sm-status-info-subtle", "fg": "--sm-status-info" } },
    { "id": "neutral", "label": "Neutral", "html": "<span class=\"badge badge-neutral\">기본</span>",   "tokens": { "bg": "--sm-background-muted", "fg": "--sm-content-secondary" } },
    { "id": "solid",   "label": "Solid",   "html": "<span class=\"badge badge-solid\">SALE</span>",    "description": "솔리드 배경 강조" },
    { "id": "count",   "label": "Count",   "html": "<span class=\"badge badge-count\">3</span>",      "description": "숫자 카운트, 원형" },
    { "id": "dot",     "label": "Dot",     "html": "<span class=\"badge badge-dot\"></span>",         "description": "상태 인디케이터 (텍스트 없음)" }
  ],
  "sizes": [
    { "id": "badge-sm", "height": 18, "fontSize": 9 },
    { "id": "badge-md", "height": 20, "fontSize": 10 },
    { "id": "badge-lg", "height": 24, "fontSize": 11 }
  ],
  "states": ["rest"],
  "tokens": {
    "bg":     "--cm-badge-{variant}-bg",
    "fg":     "--cm-badge-{variant}-fg",
    "radius": "--cm-badge-radius"
  },
  "accessibility": {
    "role": "status (상태 알림) 또는 일반 span",
    "ariaNotes": [
      "동적 카운트 업데이트 시 aria-live=polite 부모 요소 권장",
      "dot은 시각 정보만 — 의미 정보는 텍스트로 중복 제공 (예: '새 알림 3개')"
    ]
  },
  "whenToUse": ["상태 표시", "알림 카운트", "카테고리 태그", "NEW·HOT 강조"],
  "whenNotToUse": ["상호작용 필요 시 Chip 사용", "긴 텍스트 (2단어 이상)"],
  "uxWriting": ["1-3 글자 권장", "대문자 모노 또는 숫자", "동적 수치는 tabular-nums"],
  "usedInDemos": ["demo-community", "demo-store", "demo-todo", "demo-booking", "demo-foodorder", "demo-shopping", "demo-social", "demo-banking", "demo-mypage", "demo-chat", "demo-notify"],
  "relatedDocs": { "md": "components/badge.md", "sourceHtml": "index.html#badge" }
}
