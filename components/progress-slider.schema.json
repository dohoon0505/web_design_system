{
  "$schema": "../schemas/component.schema.json",
  "id": "progress",
  "name": "Progress · Slider",
  "version": "0.2.0",
  "category": "data",
  "description": "Progress는 시간 경과·완료율 표시 (수동적), Slider는 값 선택 (상호작용).",
  "variants": [
    {
      "id": "progress-bar",
      "label": "Progress Bar",
      "html": "<div class=\"progress\"><div class=\"progress-fill\" style=\"width:60%;\"></div></div>"
    },
    {
      "id": "progress-segment",
      "label": "Progress · Segment",
      "description": "단계별 분리된 진행",
      "html": "<div class=\"progress-segments\">\n  <span class=\"seg is-done\"></span>\n  <span class=\"seg is-done\"></span>\n  <span class=\"seg is-current\"></span>\n  <span class=\"seg\"></span>\n</div>"
    },
    {
      "id": "progress-circular",
      "label": "Progress · Circular",
      "description": "원형 진행 (SVG)",
      "html": "<svg class=\"progress-circular\" viewBox=\"0 0 36 36\">...</svg>"
    },
    {
      "id": "slider-single",
      "label": "Slider · Single",
      "description": "단일 값",
      "html": "<div class=\"slider\"><div class=\"slider-fill\" style=\"width:40%;\"></div><div class=\"slider-thumb\"></div></div>"
    },
    {
      "id": "slider-range",
      "label": "Slider · Range",
      "description": "이중 썸 (범위)",
      "html": "<div class=\"slider slider-range\"><div class=\"slider-fill\"></div><div class=\"slider-thumb slider-thumb-min\"></div><div class=\"slider-thumb slider-thumb-max\"></div></div>"
    }
  ],
  "states": ["idle", "loading", "complete", "error", "hover (slider)", "dragging (slider)"],
  "tokens": {
    "track":    "--sm-background-muted",
    "fill":     "--sm-interactive-brand-default",
    "thumb":    "--sm-surface-default",
    "thumbRing":"--sm-interactive-brand-default",
    "height":   "6px (bar), 4px (segment)",
    "radius":   "--radius-full"
  },
  "accessibility": {
    "role": "progressbar (Progress) 또는 slider (Slider)",
    "ariaNotes": [
      "Progress: aria-valuenow, aria-valuemin=0, aria-valuemax=100",
      "Slider: 동일 + aria-valuetext (포맷된 값), 키보드 Arrow 지원",
      "불확정 진행: aria-valuenow 생략 + 애니메이션"
    ],
    "keyboardSupport": ["Slider: Arrow Left/Right (1 step)", "Home/End", "PageUp/Down (10 step)"]
  },
  "whenToUse": [
    "Progress: 업로드·다운로드·단계 완료율",
    "Slider: 음량·밝기·가격 범위·이미지 크롭"
  ],
  "whenNotToUse": [
    "유한 선택지 → Segment / Radio",
    "500ms 미만 로딩 → Skeleton 또는 아무것도 표시하지 않음"
  ],
  "uxWriting": [
    "Progress: % 또는 x/y 표기 (3/5 완료)",
    "Slider: 값 표시에 단위 포함 (12px, ₩15,000)"
  ],
  "usedInDemos": ["demo-signup", "demo-todo"],
  "relatedDocs": { "md": "components/progress-slider.md", "sourceHtml": "index.html#progress" }
}
