{
  "$meta": {
    "name": "Typography Tokens",
    "description": "Pretendard Variable 한 벌로 모든 위계를 구성합니다. 한국어의 시각 밀도를 고려해 line-height를 넉넉히, tracking은 크기에 따라 조정됩니다. v0.4.1부터 mono 패밀리도 Pretendard로 통합되어, 숫자/메타 라벨이 한국어와 같은 메트릭을 공유합니다.",
    "version": "0.4.1",
    "sourceHtml": "UIUX-DH-design-system.html#L115-L138"
  },
  "families": {
    "sans": {
      "css": "--font-sans",
      "value": "\"Pretendard Variable\", Pretendard, -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
      "use": "모든 본문·제목의 기본"
    },
    "mono": {
      "css": "--font-mono",
      "value": "\"Pretendard Variable\", Pretendard, -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
      "use": "라벨·메타·숫자 강조 — v0.4.1부터 Pretendard로 통합. 등폭 숫자가 필요하면 `font-variant-numeric: tabular-nums` 병용.",
      "note": "변수 이름(--font-mono)은 의미적 역할(라벨/메타) 표시를 위해 유지됩니다. 물리적 폰트는 --font-sans와 동일합니다."
    }
  },
  "scale": {
    "display-lg": { "css": "--text-display-lg", "weight": 700, "size": "56px", "lineHeight": 1.1,  "tracking": "-0.035em", "use": "히어로 최대 타이틀" },
    "display-md": { "css": "--text-display-md", "weight": 700, "size": "44px", "lineHeight": 1.12, "tracking": "-0.03em",  "use": "섹션 타이틀" },
    "display-sm": { "css": "--text-display-sm", "weight": 700, "size": "36px", "lineHeight": 1.2,  "tracking": "-0.025em", "use": "부제목" },
    "heading-lg": { "css": "--text-heading-lg", "weight": 700, "size": "28px", "lineHeight": 1.3,  "tracking": "-0.02em",  "use": "페이지 헤더" },
    "heading-md": { "css": "--text-heading-md", "weight": 700, "size": "22px", "lineHeight": 1.35, "tracking": "-0.015em", "use": "카드 제목" },
    "heading-sm": { "css": "--text-heading-sm", "weight": 600, "size": "18px", "lineHeight": 1.4,  "tracking": "-0.01em",  "use": "블록 제목" },
    "body-lg":    { "css": "--text-body-lg",    "weight": 400, "size": "17px", "lineHeight": 1.55, "use": "강조 본문" },
    "body-md":    { "css": "--text-body-md",    "weight": 400, "size": "15px", "lineHeight": 1.6,  "use": "기본 본문 (default)" },
    "body-sm":    { "css": "--text-body-sm",    "weight": 400, "size": "13px", "lineHeight": 1.55, "use": "보조 본문 · 설명" },
    "label-lg":   { "css": "--text-label-lg",   "weight": 600, "size": "15px", "lineHeight": 1.4,  "use": "큰 라벨·버튼" },
    "label-md":   { "css": "--text-label-md",   "weight": 600, "size": "13px", "lineHeight": 1.4,  "use": "라벨·버튼" },
    "label-sm":   { "css": "--text-label-sm",   "weight": 600, "size": "11px", "lineHeight": 1.4,  "use": "태그·뱃지" },
    "caption":    { "css": "--text-caption",    "weight": 500, "size": "12px", "lineHeight": 1.45, "use": "캡션·도움말" },
    "overline":   { "css": "--text-overline",   "weight": 600, "size": "11px", "lineHeight": 1.4,  "tracking": "0.08em", "transform": "uppercase", "use": "섹션 메타 · 태그" }
  }
}
