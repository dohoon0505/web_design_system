{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/auto-commit-push.sh",
            "shell": "bash",
            "timeout": 60,
            "statusMessage": "Auto-committing & pushing changes..."
          }
        ]
      }
    ]
  }
}
