        },
        {
          "type": "code",
          "lang": "HTML",
          "title": "HTML",
          "value": "<div class=\"scroll-track\">\n  <div class=\"sticky-stage\">\n    <div class=\"card\" data-i=\"0\">\n      <div class=\"inner\">\n        <div class=\"text\">넘버링 + 타이틀 + 본문 + CTA</div>\n        <div class=\"img-wrap\"><div class=\"img\">이미지</div></div>\n      </div>\n    </div>\n    <!-- ×4 카드 래퍼(배경) + inner(실제 카드) -->\n  </div>\n</div>"
        },
        {
          "type": "code",
          "lang": "CSS",
          "title": "CSS",
          "value": ".scroll-track { min-height: 500vh; }\n.sticky-stage { position: sticky; top: 0; height: 100vh; overflow: hidden; background: linear-gradient(...); }\n.card { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; padding: 40px;\n  transform: translateY(100%); will-change: transform; }\n.card[data-i=\"0\"] { transform: translateY(0); }\n.inner { width: 100%; max-width: 1100px; display: grid; grid-template-columns: 1fr 1fr;\n  background: rgba(255,255,255,0.55); border-radius: 32px; backdrop-filter: blur(20px); }"
        },
        {
          "type": "code",
          "lang": "JS",
          "title": "JavaScript",
          "value": "cards.forEach(function(c, i){\n  var pos = p * N - i;\n  var local = Math.max(0, Math.min(1, pos + 1));\n  var ease = 1 - Math.pow(1 - local, 3);\n  c.style.transform = \"translateY(\" + (100 * (1 - ease)) + \"%)\";\n  c.style.zIndex = i;\n});"
        },
