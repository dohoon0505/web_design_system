        {
          "type": "code",
          "lang": "HTML",
          "title": "HTML",
          "value": "<div class=\"scroll-track\">\n  <div class=\"sticky-stage\">\n    <div class=\"card\" data-i=\"0\" style=\"background:linear-gradient(...)\">\n      <div class=\"inner\">\n        <div class=\"text\">넘버링 + 타이틀 + 본문 + CTA</div>\n        <div class=\"img-wrap\"><img src=\"...\" alt=\"\"></div>\n      </div>\n    </div>\n    <!-- x4 카드 (각자 그라디언트 배경) -->\n  </div>\n</div>"
