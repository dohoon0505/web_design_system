        },
        {
          "type": "code",
          "lang": "CSS",
          "title": "CSS",
          "value": ".card { clip-path: inset(100% 0 0 0); }\n.card[data-i=\"0\"] { clip-path: inset(0); }"
        },
        {
          "type": "code",
          "lang": "JS",
          "title": "JavaScript",
          "value": "cards.forEach(function(c, i){\n  if (i === 0) return;\n  var pos = p * N - i + 1;\n  var inset = pos <= 0 ? 100 : pos >= 1 ? 0 : (1 - pos) * 100;\n  c.style.clipPath = \"inset(\" + inset + \"% 0 0 0)\";\n  c.style.zIndex = i;\n});"
