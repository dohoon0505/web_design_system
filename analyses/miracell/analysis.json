        ]},
        { "type": "heading", "value": "그리드 시스템" },
        { "type": "kv", "columns": 1, "items": [
          { "label": "서비스 섹션", "value": "3열 균등 그리드, gap 0, 풀 와이드" },
          { "label": "제품 섹션", "value": "5열 균등 그리드, gap 16px, max-width 1200px" },
